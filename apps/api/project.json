{
  "name": "@org/api",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/api/src",
  "projectType": "application",
  "targets": {
    "serve": {
      "continuous": true,
      "executor": "nx:run-commands",
      "options": {
        "command": "npx ts-node --project apps/api/tsconfig.app.json apps/api/src/main.ts",
        "cwd": "."
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx tsc -p apps/api/tsconfig.app.json",
        "cwd": "."
      }
    }
  },
  "tags": []
}