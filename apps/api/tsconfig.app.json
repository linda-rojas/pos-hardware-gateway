{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "rootDir": "./src",
        "outDir": "../../dist/apps/api",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "target": "ES2021",
        "types": [
            "node"
        ],
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true
    },
    "exclude": [
        "jest.config.ts",
        "src/**/*.spec.ts",
        "src/**/*.test.ts"
    ],
    "include": [
        "src/**/*.ts"
    ]
}